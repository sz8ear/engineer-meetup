---

<section id="organizers">
  <div class="container">
    <p class="section-tag" style="color: var(--pink);">👥 Organizers</p>
    <h2 class="section-title">主催者</h2>

    <div class="organizers-grid">
      {organizers.map((org) => (
        <button
          type="button"
          class="organizer-card"
          data-modal={org.id}
          aria-haspopup="dialog"
        >
          <div class="organizer-avatar">
            <img src={org.avatar} alt={org.name} />
          </div>
          <div class="organizer-handle">{org.name}</div>
          <div class="organizer-x">𝕏 {org.xHandle}</div>
        </button>
      ))}
    </div>
  </div>
</section>

<!-- モーダル -->
{organizers.map((org) => (
  <div
    id={`modal-${org.id}`}
    class="modal-overlay"
    role="dialog"
    aria-modal="true"
    aria-labelledby={`modal-title-${org.id}`}
  >
    <div class="modal">
      <div class="modal-header">
        <div class="modal-avatar">
          <img src={org.avatar} alt={org.name} />
        </div>
        <div class="modal-title">
          <h3 id={`modal-title-${org.id}`}>{org.name}</h3>
          <a href={org.xUrl} target="_blank" rel="noopener noreferrer">{org.xHandle}</a>
        </div>
        <button type="button" class="modal-close" aria-label="閉じる">✕</button>
      </div>
      <div class="modal-body">
        {org.bio && <p>{org.bio}</p>}
        {org.message && <p class="modal-message">{org.message}</p>}
        {org.links.length > 0 && (
          <div class="modal-links">
            {org.links.map((link) => (
              <a href={link.url} target="_blank" rel="noopener noreferrer">
                🔗 {link.label}
              </a>
            ))}
          </div>
        )}
      </div>
    </div>
  </div>
))}
